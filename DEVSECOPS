                docker network inspect ${ZAP_NET} >/dev/null 2>&1 || docker network create ${ZAP_NET}
                docker rm -f ${APP_NAME} >/dev/null 2>&1 || true
                docker run -d --name ${APP_NAME} --network ${ZAP_NET} -p 4000:3000 bkimminich/juice-shop
